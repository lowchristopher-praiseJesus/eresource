# Database (auto-provided by Render when using render.yaml; set manually for local dev)
DATABASE_URL="postgresql://user:password@localhost:5432/eresource"

# NextAuth — generate NEXTAUTH_SECRET with: openssl rand -base64 32
# Render auto-generates NEXTAUTH_SECRET via render.yaml generateValue: true
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# Production example: NEXTAUTH_URL="https://eresource.onrender.com"

# Cloudflare R2 file storage
# Dashboard → R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="eresource"
# Public CDN domain for serving files, e.g. https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_URL=""

# Upload limit in bytes — default 500 MB
MAX_UPLOAD_BYTES="524288000"
