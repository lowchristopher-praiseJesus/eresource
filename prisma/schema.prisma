generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resource {
  id            String       @id @default(cuid())
  name          String
  description   String?
  tags          String[]
  category      Category
  resourceType  ResourceType
  fileKey       String?
  youtubeUrl    String?
  mimeType      String?
  fileSizeBytes Int?
  isPinned      Boolean      @default(false)
  pinnedOrder   Int?
  likeCount     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  topics        ResourceTopic[]

  @@index([category])
  @@index([isPinned, pinnedOrder])
  @@index([createdAt(sort: Desc)])
}

model Topic {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  order       Int
  createdAt   DateTime        @default(now())
  resources   ResourceTopic[]
}

model ResourceTopic {
  resourceId  String
  topicId     String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([resourceId, topicId])
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum Category {
  VIDEO
  AUDIO
  DOCUMENT
  PICTURE
}

enum ResourceType {
  FILE
  YOUTUBE
}
